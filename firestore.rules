rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Orders collection - users can read their own orders and create new ones
    match /orders/{orderId} {
      // Allow users to create orders
      allow create: if request.auth != null;
      
      // Allow users to read their own orders
      allow read: if request.auth != null && 
                     (resource.data.userId == request.auth.uid || 
                      request.auth.token.admin == true);
      
      // Allow admins to update and delete orders
      allow update, delete: if request.auth != null && 
                               request.auth.token.admin == true;
    }
    
    // User profiles collection - users can read/write their own profile
    match /userProfiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Products collection - everyone can read, only admins can write
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    
    // Categories collection - everyone can read, only admins can write
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    
    // Featured/Offers collection - everyone can read, only admins can write
    match /featured/{featuredId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    
    match /offers/{offerId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
